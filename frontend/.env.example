# Frontend configuration — copy to .env and adjust
# Backend the dev-server /api proxy forwards to
VITE_API_TARGET=http://localhost:16000

# Dev server bind address (0.0.0.0 exposes it on the LAN for mobile testing)
VITE_HOST=0.0.0.0

# Subpath mounting (e.g. inside a portfolio site at /assistant)
# VITE_BASE=/assistant/
# VITE_API_BASE=/assistant-api

# Set to 'true' to run Whisper transcription in the browser via WASM (tiny.en, ~75MB cache).
# Default (false) sends audio to the Pi /transcribe endpoint instead.
# VITE_WHISPER_WASM=false

# Set to 'true' to run Piper TTS in the browser via WASM (en_US-amy-medium, ~60MB).
# Default (false) calls the Pi /speak endpoint instead.
# VITE_PIPER_WASM=false
