# Frontend configuration — copy to .env and adjust
# Backend the dev-server /api proxy forwards to
VITE_API_TARGET=http://localhost:16000

# Dev server bind address (0.0.0.0 exposes it on the LAN for mobile testing)
VITE_HOST=0.0.0.0

# Subpath mounting (e.g. inside a portfolio site at /assistant)
# VITE_BASE=/assistant/
# VITE_API_BASE=/assistant-api
