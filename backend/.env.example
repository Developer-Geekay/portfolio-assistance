# Backend configuration — copy to .env and adjust
# Server
HOST=0.0.0.0
PORT=16000

# Admin key for analytics endpoints (/conversations, /sessions, /leads,
# /unknown-queries, /retrain). Endpoints stay disabled until this is set.
ADMIN_KEY=change-me-to-a-long-random-string

# The person this assistant represents
PERSONA_NAME=Alex
PERSONA_FULL_NAME=Alex Morgan
# Contact wording used when deflecting personal/career questions,
# e.g. "at alex@example.com or on LinkedIn"
PERSONA_CONTACT=via the contact links on this site

# Comma-separated proper nouns to improve speech recognition accuracy,
# e.g. "Alex Morgan, Example Corp, OpenBudget, Kubernetes"
WHISPER_PROMPT=skills, projects, experience, certifications

# Models
LLM_MODEL=models/generator/gemma-4-e2b-it-qat-q4.gguf
LLM_THREADS=4
WHISPER_MODEL=base.en
PIPER_VOICE=models/tts/en_US-lessac-medium.onnx

# Knowledge base — start from knowledge_base.sample.json
# (knowledge_base.json is gitignored: your personal facts never get committed)
KB_PATH=knowledge_base.json
