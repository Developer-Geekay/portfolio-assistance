# Backend configuration — copy to .env and adjust
# Server
GOKUL_HOST=0.0.0.0
GOKUL_PORT=16000

# Admin key for analytics endpoints (/conversations, /sessions, /leads,
# /unknown-queries, /retrain). Endpoints stay disabled until this is set.
GOKUL_ADMIN_KEY=change-me-to-a-long-random-string

# Models
GOKUL_LLM_MODEL=models/generator/gemma-4-e2b-it-qat-q4.gguf
GOKUL_LLM_THREADS=4
GOKUL_WHISPER_MODEL=base.en
GOKUL_PIPER_VOICE=models/tts/en_US-lessac-medium.onnx

# Knowledge base
GOKUL_KB_PATH=knowledge_base.json
